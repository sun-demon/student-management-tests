{
  "info": {
    "name": "Student Management API",
    "description": "Коллекция Postman для тестирования API сервиса управления студентами",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://127.0.0.1:5000"},
    {"key": "username", "value": "admin_demo"},
    {"key": "password", "value": "DemoPass123!"},
    {"key": "token", "value": ""},
    {"key": "studentId", "value": "1"}
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('token', json.access_token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/login"
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/logout"
          }
        }
      ]
    },
    {
      "name": "Students",
      "item": [
        {
          "name": "Add Student - Valid",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  pm.collectionVariables.set('studentId', pm.response.json().id);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Иванов Иван Иванович\",\n  \"age\": 20,\n  \"gender\": \"М\",\n  \"enrollment_date\": \"2024-09-01\",\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/add-user"
          }
        },
        {
          "name": "Add Student - Invalid Age",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Петров Пётр\",\n  \"age\": -10,\n  \"gender\": \"М\"\n}"
            },
            "url": "{{baseUrl}}/add-user"
          }
        },
        {
          "name": "Add Student - Invalid Gender",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Тестов Тест\",\n  \"age\": 21,\n  \"gender\": \"X\"\n}"
            },
            "url": "{{baseUrl}}/add-user"
          }
        },
        {
          "name": "Get All Students",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get Student By ID",
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/user/{{studentId}}"
          }
        },
        {
          "name": "Update Student",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Обновлённый Студент\",\n  \"age\": 22,\n  \"gender\": \"Ж\"\n}"
            },
            "url": "{{baseUrl}}/user/{{studentId}}"
          }
        },
        {
          "name": "Update Nonexistent Student",
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Несуществующий\",\n  \"age\": 20,\n  \"gender\": \"М\"\n}"
            },
            "url": "{{baseUrl}}/user/999999"
          }
        },
        {
          "name": "Delete Student",
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/user/{{studentId}}"
          }
        }
      ]
    }
  ]
}
