{
  "info": {
    "name": "Student Management API",
    "description": "Коллекция Postman для тестирования API EduManage.\n\n**Collection Runner — порядок папок важен:**\n1. `01 Setup` — Reset, Register, Login\n2. `02 Students` — CRUD (нужен token)\n3. `03 Negative` — негативные сценарии\n4. `04 Cleanup` — Logout в конце\n\nНе запускайте Logout до Students — токен станет недействительным.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {"key": "baseUrl", "value": "http://127.0.0.1:5000"},
    {"key": "username", "value": ""},
    {"key": "password", "value": "DemoPass123!"},
    {"key": "token", "value": ""},
    {"key": "studentId", "value": "1"}
  ],
  "item": [
    {
      "name": "01 Setup",
      "description": "Reset → Register → Login. После Login token сохраняется в переменные коллекции.",
      "item": [
        {
          "name": "00 Reset State (local mock)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Reset returns 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('State cleared message', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.message).to.include('сброшено');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/reset",
            "description": "Только для локального mock-сервера. Очищает пользователей и студентов."
          }
        },
        {
          "name": "01 Register",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const uniqueUsername = 'admin_' + Date.now();",
                  "pm.collectionVariables.set('username', uniqueUsername);",
                  "pm.collectionVariables.set('password', 'DemoPass123!');",
                  "pm.collectionVariables.unset('token');",
                  "console.log('New username:', uniqueUsername);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains username', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.username).to.eql(pm.collectionVariables.get('username'));",
                  "});",
                  "",
                  "pm.test('Registration success message', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.message).to.be.a('string');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/register",
            "description": "Перед запросом автоматически генерируется уникальный username."
          }
        },
        {
          "name": "02 Login",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const username = pm.collectionVariables.get('username');",
                  "if (!username) {",
                  "    throw new Error('Сначала выполните Register — username пустой');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Access token received', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.access_token).to.be.a('string').and.not.empty;",
                  "    pm.collectionVariables.set('token', json.access_token);",
                  "});",
                  "",
                  "pm.test('Token type is Bearer', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.token_type).to.eql('Bearer');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"{{password}}\"\n}"
            },
            "url": "{{baseUrl}}/login",
            "description": "Использует username/password из Register. Сохраняет token."
          }
        }
      ]
    },
    {
      "name": "02 Students",
      "description": "CRUD студентов. Требуется token из 01 Setup → Login.",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "type": "text/javascript",
            "exec": [
              "const token = pm.collectionVariables.get('token');",
              "if (!token) {",
              "    throw new Error('Нет token. Сначала выполните папку 01 Setup (Register + Login)');",
              "}"
            ]
          }
        }
      ],
      "item": [
        {
          "name": "Add Student - Valid",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('token')) {",
                  "    throw new Error('Нет токена. Выполните Auth → Register, затем Login');",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Student has required fields', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.full_name).to.eql('Иванов Иван Иванович');",
                  "    pm.expect(json.age).to.eql(20);",
                  "    pm.expect(json.gender).to.eql('М');",
                  "    pm.expect(json.id).to.be.a('number');",
                  "    pm.collectionVariables.set('studentId', json.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Иванов Иван Иванович\",\n  \"age\": 20,\n  \"gender\": \"М\",\n  \"enrollment_date\": \"2024-09-01\",\n  \"is_active\": true\n}"
            },
            "url": "{{baseUrl}}/add-user"
          }
        },
        {
          "name": "Add Student - Invalid Age",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 Bad Request', function () {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Validation errors returned', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.errors).to.be.an('array').that.is.not.empty;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Петров Пётр\",\n  \"age\": -10,\n  \"gender\": \"М\"\n}"
            },
            "url": "{{baseUrl}}/add-user"
          }
        },
        {
          "name": "Add Student - Invalid Gender",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 Bad Request', function () {",
                  "    pm.response.to.have.status(400);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Тестов Тест\",\n  \"age\": 21,\n  \"gender\": \"X\"\n}"
            },
            "url": "{{baseUrl}}/add-user"
          }
        },
        {
          "name": "Get All Students",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is array', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/users"
          }
        },
        {
          "name": "Get Student By ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Student ID matches', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.eql(Number(pm.collectionVariables.get('studentId')));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/user/{{studentId}}"
          }
        },
        {
          "name": "Update Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Name updated', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.full_name).to.eql('Обновлённый Студент');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Обновлённый Студент\",\n  \"age\": 22,\n  \"gender\": \"Ж\"\n}"
            },
            "url": "{{baseUrl}}/user/{{studentId}}"
          }
        },
        {
          "name": "Update Nonexistent Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404 Not Found', function () {",
                  "    pm.response.to.have.status(404);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
              {"key": "Content-Type", "value": "application/json"},
              {"key": "Authorization", "value": "Bearer {{token}}"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Несуществующий\",\n  \"age\": 20,\n  \"gender\": \"М\"\n}"
            },
            "url": "{{baseUrl}}/user/999999"
          }
        },
        {
          "name": "Delete Student",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "DELETE",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/user/{{studentId}}"
          }
        }
      ]
    },
    {
      "name": "03 Negative",
      "description": "Негативные сценарии. Запускать после 02 Students.",
      "item": [
        {
          "name": "Login - Wrong Password",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401 Unauthorized', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{username}}\",\n  \"password\": \"wrong_password\"\n}"
            },
            "url": "{{baseUrl}}/login"
          }
        },
        {
          "name": "Add Student - No Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401 Unauthorized', function () {",
                  "    pm.response.to.have.status(401);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Content-Type", "value": "application/json"}],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"full_name\": \"Без Токена\",\n  \"age\": 20,\n  \"gender\": \"М\"\n}"
            },
            "url": "{{baseUrl}}/add-user"
          }
        }
      ]
    },
    {
      "name": "04 Cleanup",
      "description": "Logout — только в конце прогона!",
      "item": [
        {
          "name": "Logout",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Logout message received', function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.message).to.be.a('string');",
                  "});",
                  "",
                  "pm.collectionVariables.unset('token');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{"key": "Authorization", "value": "Bearer {{token}}"}],
            "url": "{{baseUrl}}/logout"
          }
        }
      ]
    }
  ]
}
